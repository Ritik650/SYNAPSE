# Synapse Environment Variables
# Copy this to .env and fill in your values

# Anthropic
ANTHROPIC_API_KEY=sk-ant-your-key-here

# JWT
JWT_SECRET_KEY=change-me-in-production-use-a-long-random-string
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=10080

# Database
DATABASE_URL=sqlite:///./synapse.db

# Backend
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Frontend
VITE_API_URL=http://localhost:8000/api/v1

# Environment data (optional — for AQI/weather)
OPENMETEO_BASE_URL=https://api.open-meteo.com/v1
IQAIR_API_KEY=

# Demo
DEMO_USER_EMAIL=aarav@synapse.demo
DEMO_USER_PASSWORD=synapse-demo-2024
